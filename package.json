{
  "name": "aspect-grid-collageify",
  "version": "2.1.0",
  "description": "A lightweight, pure frontend canvas-based smart photo collage core with optional visual editing.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.mjs",
      "require": "./dist/core.js"
    },
    "./editor": {
      "types": "./dist/editor.d.ts",
      "import": "./dist/editor.mjs",
      "require": "./dist/editor.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts src/core.ts src/editor.ts --format esm,cjs --dts --clean",
    "prepublishOnly": "pnpm build",
    "release": "pnpm publish"
  },
  "files": [
    "dist",
    "README.md",
    "README_EN.md",
    "LICENSE"
  ],
  "keywords": [
    "collage",
    "puzzle",
    "canvas",
    "aspect-ratio",
    "grid",
    "photo-collage",
    "offscreen-rendering"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liuxin2533/aspect-grid-collageify"
  },
  "homepage": "https://liuxin2533.github.io/aspect-grid-collageify/",
  "bugs": {
    "url": "https://github.com/liuxin2533/aspect-grid-collageify/issues"
  },
  "author": "liuxin2533",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "onlyBuiltDependencies": [
    "esbuild"
  ]
}